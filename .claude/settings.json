{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "NOISY_CODING_LISTENER_PORT=7765 python3 \"$CLAUDE_PROJECT_DIR/hooks/user_prompt_submit.py\"",
            "timeout": 5,
            "statusMessage": "Reporting activity (dev)"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__noisy-coding-dev__speak",
        "hooks": [
          {
            "type": "command",
            "command": "NOISY_CODING_LISTENER_PORT=7765 python3 \"$CLAUDE_PROJECT_DIR/hooks/pre_speak.py\"",
            "timeout": 5,
            "statusMessage": "Showing spoken text (dev)"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "NOISY_CODING_LISTENER_PORT=7765 python3 \"$CLAUDE_PROJECT_DIR/hooks/pre_tool_use.py\"",
            "timeout": 5,
            "statusMessage": "Reporting activity (dev)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "NOISY_CODING_LISTENER_PORT=7765 python3 \"$CLAUDE_PROJECT_DIR/hooks/post_tool_use.py\"",
            "timeout": 5,
            "statusMessage": "Checking voice queue (dev)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "NOISY_CODING_LISTENER_PORT=7765 python3 \"$CLAUDE_PROJECT_DIR/hooks/stop.py\"",
            "timeout": 3630,
            "asyncRewake": true,
            "statusMessage": "Listening for your voice (dev)",
            "rewakeSummary": "🎙️ Voice message received (dev)"
          }
        ]
      }
    ]
  }
}
