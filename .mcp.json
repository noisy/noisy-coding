{
  "mcpServers": {
    "noisy-coding": {
      "type": "stdio",
      "command": "sh",
      "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/mcp_exec.sh"]
    },
    "noisy-coding-dev": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "noisy-coding-mcp"
      ],
      "env": {
        "NOISY_CODING_LISTENER_PORT": "7765"
      }
    }
  }
}