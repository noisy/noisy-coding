{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/hooks/exec.sh\" user_prompt_submit.py",
            "timeout": 5,
            "statusMessage": "Reporting activity"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__noisy-coding__speak",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/hooks/exec.sh\" pre_speak.py",
            "timeout": 5,
            "statusMessage": "Showing spoken text"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/hooks/exec.sh\" pre_tool_use.py",
            "timeout": 5,
            "statusMessage": "Reporting activity"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/hooks/exec.sh\" post_tool_use.py",
            "timeout": 5,
            "statusMessage": "Checking voice queue"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/hooks/exec.sh\" stop.py NOISY_CODING_STOP_MODE=rewake",
            "timeout": 1830,
            "asyncRewake": true,
            "statusMessage": "Listening for your voice",
            "rewakeSummary": "🎙️ Voice message received"
          }
        ]
      }
    ]
  }
}
